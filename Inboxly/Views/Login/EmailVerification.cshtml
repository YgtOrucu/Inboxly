@model ConfirmCodeDto
@{
    Layout = null;
}

<!DOCTYPE html>

<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Mailify OTP Verification</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#c880ff",
                        "accent-pink": "#FF6FD8",
                        "background-light": "#f7f5f8",
                        "background-dark": "#1a0f23",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.5rem",
                        "lg": "0.625rem", /* 10px */
                        "xl": "1rem",
                        "2xl": "1.25rem", /* 20px */
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
    <style>
        .gradient-text {
            background: linear-gradient(to right, #FF6FD8, #c880ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .gradient-bg {
            background: linear-gradient(135deg, #FF6FD8 0%, #c880ff 100%);
        }

        .input-glow:focus {
            box-shadow: 0 0 15px rgba(200, 128, 255, 0.3);
        }
        /* Hide spin buttons for numeric inputs */
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        input[type=number] {
            -moz-appearance: textfield;
        }
    </style>
</head>
<body class="font-display bg-background-light dark:bg-background-dark min-h-screen flex items-center justify-center p-4">

    <div class="fixed inset-0 z-[-1]">
        <img src="/mendy-admin/package/assets/images/big/auth-bg.jpg" alt="Modern ofis alanı" class="w-full h-full object-cover" />
        <div class="absolute inset-0"></div>
    </div>

    <main class="relative z-10 w-full max-w-[450px] bg-white dark:bg-[#241731] rounded-2xl shadow-2xl overflow-hidden border border-white/20">
        <div class="px-8 pt-10 pb-12 flex flex-col items-center">

            <div class="mb-8 flex items-center justify-center size-16 rounded-xl gradient-bg shadow-lg shadow-primary/20">
                <svg class="text-white" fill="none" height="36" viewBox="0 0 48 48" width="36" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 6H42L36 24L42 42H6L12 24L6 6Z" fill="currentColor"></path>
                </svg>
            </div>

            <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2 text-center tracking-tight">
                E-posta Doğrulama
            </h1>

            <p class="text-gray-500 dark:text-gray-400 text-center text-sm leading-relaxed mb-10 max-w-[320px]">
                E-posta adresinize gönderilen 6 haneli doğrulama kodunu giriniz.
            </p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mb-6 rounded-xl bg-red-50 border border-red-200 p-4 text-sm text-red-700">
                    <div class="font-bold mb-2">
                        Lütfen aşağıdaki hataları düzeltiniz
                    </div>

                    @Html.ValidationSummary(true, "", new { @class = "list-disc list-inside space-y-1" })
                </div>
            }

            <form class="w-full" method="post" id="otpForm">

                <div class="flex justify-between gap-2 mb-10">
                    <input class="otp-input size-12 md:size-14 text-center text-xl font-bold bg-gray-50 dark:bg-background-dark/50 border-gray-200 dark:border-gray-700 border rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all text-gray-900 dark:text-white" inputmode="numeric" pattern="[0-9]" maxlength="1" type="text" />
                    <input class="otp-input size-12 md:size-14 text-center text-xl font-bold bg-gray-50 dark:bg-background-dark/50 border-gray-200 dark:border-gray-700 border rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all text-gray-900 dark:text-white" inputmode="numeric" pattern="[0-9]" maxlength="1" type="text" />
                    <input class="otp-input size-12 md:size-14 text-center text-xl font-bold bg-gray-50 dark:bg-background-dark/50 border-gray-200 dark:border-gray-700 border rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all text-gray-900 dark:text-white" inputmode="numeric" pattern="[0-9]" maxlength="1" type="text" />
                    <input class="otp-input size-12 md:size-14 text-center text-xl font-bold bg-gray-50 dark:bg-background-dark/50 border-gray-200 dark:border-gray-700 border rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all text-gray-900 dark:text-white" inputmode="numeric" pattern="[0-9]" maxlength="1" type="text" />
                    <input class="otp-input size-12 md:size-14 text-center text-xl font-bold bg-gray-50 dark:bg-background-dark/50 border-gray-200 dark:border-gray-700 border rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all text-gray-900 dark:text-white" inputmode="numeric" pattern="[0-9]" maxlength="1" type="text" />
                    <input class="otp-input size-12 md:size-14 text-center text-xl font-bold bg-gray-50 dark:bg-background-dark/50 border-gray-200 dark:border-gray-700 border rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all text-gray-900 dark:text-white" inputmode="numeric" pattern="[0-9]" maxlength="1" type="text" />
                </div>

                <input type="hidden" name="ConfirmCode" id="otpCode" />

                <button type="submit"
                        class="w-full h-14 gradient-bg text-white font-semibold text-base rounded-lg shadow-lg shadow-primary/30 hover:shadow-primary/40 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                    Doğrula ve Devam Et
                    <span class="material-symbols-outlined text-lg">arrow_forward</span>
                </button>
            </form>
        </div>
    </main>

    <script>
         const inputs = document.querySelectorAll(".otp-input");
        const hiddenInput = document.getElementById("otpCode");
        const form = document.getElementById("otpForm");

        inputs.forEach((input, index) => {
            input.addEventListener("input", () => {
                if (input.value && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
            });

            input.addEventListener("keydown", (e) => {
                if (e.key === "Backspace" && !input.value && index > 0) {
                    inputs[index - 1].focus();
                }

                if (e.key === "Enter") {
                    submitOtp();
                }
            });
        });

        form.addEventListener("submit", () => {
            submitOtp();
        });

        function submitOtp() {
            let code = "";
            inputs.forEach(i => code += i.value);
            hiddenInput.value = code;
        }
    </script>
</body>
</html>