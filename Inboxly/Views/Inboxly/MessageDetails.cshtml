@model EmailDetailsDto
@{
    ViewData["Title"] = "MessageDetails";
    Layout = "~/Views/Shared/_InboxlyLayout.cshtml";
    var content = Model.Details;
    var index = content.IndexOf(",");
    string firstPart = index > -1 ? content.Substring(0, index + 1) : content;
    string secondPart = index > -1 ? content.Substring(index + 1) : "";
    string action = Model.MessageStatusId switch
    {
        1 => "Inbox",
        2 => "SendBox",
        3 => "ListDrafts",
        4 => "ListStarsMessages",
        6 => "ListDeletedMessages"
    };
}

<div class="container-fluid">
    <div class="email-app">

        @await Component.InvokeAsync("LeftBarInTheMailOperations")
        <div class="right-part mail-details bg-white" style="margin-left:260px;">
            <div class="card-body">
                @if (Model.MessageStatusId == 1)
                {
                    <a asp-controller="Inboxly" asp-action=@action type="button" id="back_to_inbox" class="btn btn-outline-secondary font-18 m-r-10">
                        <i class="mdi mdi-arrow-left"></i>
                    </a>
                }
                else
                {
                    <a asp-controller="Inboxly" asp-action=@action type="button" id="back_to_inbox" class="btn btn-outline-secondary font-18 m-r-10">
                        <i class="mdi mdi-arrow-left"></i>
                    </a>
                }
            </div>
            <div class="card-body border-top border-bottom bg-light">
                <h4 class="m-b-0">Mesaj Ayrıntıları</h4>
            </div>
            <div class="card-body border-bottom">
                <div class="d-flex no-block align-items-center m-b-40">
                    <div class="m-r-10">
                        <div class="user-initials-lg">
                            @Model.Name.Substring(0, 1)@Model.Surname.Substring(0, 1)
                        </div>
                    </div>

                    <div class="">
                        <h5 class="m-b-0 font-16 font-medium">@(Model.Name + " " + Model.Surname)</h5><span>
                            @Model.Mail
                        </span>
                    </div>
                </div>
                <h4 class="m-b-15">@Html.Raw(firstPart)</h4>
                <p>
                    @Html.Raw(secondPart)
                </p>
            </div>
        </div>
    </div>
</div>


