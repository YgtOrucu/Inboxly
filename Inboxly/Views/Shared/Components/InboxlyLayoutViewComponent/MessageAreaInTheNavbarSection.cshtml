@model MessageAreaSectionDto


<li class="nav-item dropdown">
    <a class="nav-link dropdown-toggle waves-effect waves-dark" href="" id="2" data-toggle="dropdown"
       aria-haspopup="true" aria-expanded="false">
        <i data-feather="mail"></i>
        <span class="badge badge-pill badge-danger noti">@Model.AllMessageCount</span>
    </a>
    <div class="dropdown-menu dropdown-menu-right mailbox animated bounceInDown"
         aria-labelledby="2">
        <ul class="list-style-none">
            <li>
                <div class="drop-title bg-light">
                    <h4 class="mb-0 mt-1">Mesajlar</h4>
                </div>
            </li>
            <li>
                <div class="message-center message-body">
                    @foreach(var item in Model.Messages)
                    {
                        <a href="javascript:void(0)" class="message-item">
                        <span class="user-img initials-avatar">
                            @(item.NameSurnameHead)
                        </span>
                        <div class="mail-contnet">
                            <h5 class="message-title">@(item.NameSurname)</h5>
                            <span class="mail-desc">@(item.Subject)</span>
                            <span class="time">@(item.Date)</span>
                        </div>
                    </a>  
                    }    
                </div>
            </li>
            <li>
                <a class="nav-link text-center link text-dark" href="javascript:void(0);">
                    <b>See all e-Mails</b>
                    <i class="fa fa-angle-right"></i>
                </a>
            </li>
        </ul>
    </div>
</li>