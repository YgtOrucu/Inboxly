@model SettingInTheProfilePageDto
<div class="tab-pane fade" id="previous-month" role="tabpanel" aria-labelledby="pills-setting-tab">
    <div class="card-body">
        <form asp-action="ProfileSettings" asp-controller="Profile" method="post" enctype="multipart/form-data"
              class="form-horizontal form-material">
              <input type="hidden" asp-for="AvatarImage" />
            <div class="form-group">
                <label class="col-md-12">Kullanıcı Adı</label>
                <div class="col-md-12">
                    <input asp-for="Username" class="form-control form-control-line" />
                </div>
            </div>

            <div class="form-group">
                <label class="col-md-12">Yeni Şifre</label>
                <div class="col-md-12">
                    <input asp-for="Password" type="password"
                           class="form-control form-control-line"
                           placeholder="Değiştirmek istemiyorsan boş bırak" />
                </div>
            </div>

            <div class="form-group">
                <label class="col-md-12">Telefon</label>
                <div class="col-md-12">
                    <input asp-for="PhoneNumber" class="form-control form-control-line" />
                </div>
            </div>

            <div class="form-group">
                <label class="col-md-12">Hakkımda</label>
                <div class="col-md-12">
                    <textarea asp-for="About" rows="5"
                              class="form-control form-control-line"></textarea>
                </div>
            </div>

            <div class="form-group">
                <label class="col-md-12">Adres</label>
                <div class="col-md-12">
                    <input asp-for="Address" class="form-control form-control-line" />
                </div>
            </div>

            <div class="form-group">
                <label class="col-md-12">Konum</label>
                <div class="col-md-12">
                    <input asp-for="Location" class="form-control form-control-line" />
                </div>
            </div>

            <div class="form-group">
                <label class="col-md-12">Profil Fotoğrafı</label>
                <div class="col-md-12">
                    <input asp-for="ImageFile" type="file"
                           class="form-control form-control-line" />
                </div>
            </div>

            <div class="form-group">
                <div class="col-sm-12">
                    <button type="submit" class="btn btn-success">
                        Profili Güncelle
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>